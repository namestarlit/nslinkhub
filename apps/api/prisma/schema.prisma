// Schema for the hub tenancy model (Hub → Collections → Resources).
// The migration SQL remains the source of truth for objects Prisma cannot
// model: the app_uuid_v7() function, set_updated_at triggers, the
// collection-hierarchy trigger, CHECK constraints, and the partial unique
// index uq_resources_collection_link. Future migrations: use `prisma migrate
// dev --create-only` and review the SQL so those objects are never dropped.

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(dbgenerated("app_uuid_v7()")) @db.Uuid
  name          String   @db.VarChar(255)
  email         String   @unique @db.VarChar(255)
  emailVerified Boolean  @default(false) @map("email_verified")
  image         String?
  bio           String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  hub                Hub?
  createdCollections Collection[]      @relation("CollectionCreator")
  shares             CollectionShare[]
  saves              CollectionSave[]
  exportJobs         ExportJob[]
  sessions           Session[]
  accounts           Account[]

  @@map("users")
}

model Hub {
  id          String   @id @default(dbgenerated("app_uuid_v7()")) @db.Uuid
  ownerUserId String   @unique @map("owner_user_id") @db.Uuid
  handle      String   @unique @db.VarChar(60)
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  owner       User         @relation(fields: [ownerUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  collections Collection[]
  exportJobs  ExportJob[]

  @@map("hubs")
}

model Collection {
  id                 String   @id @default(dbgenerated("app_uuid_v7()")) @db.Uuid
  hubId              String   @map("hub_id") @db.Uuid
  slug               String   @db.VarChar(120)
  title              String   @db.VarChar(255)
  description        String?
  published          Boolean  @default(false)
  linkSharingEnabled Boolean  @default(false) @map("link_sharing_enabled")
  shareTokenHash     String?  @map("share_token_hash") @db.VarChar(255)
  parentCollectionId String?  @map("parent_collection_id") @db.Uuid
  creatorUserId      String?  @map("creator_user_id") @db.Uuid
  version            BigInt   @default(1)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  hub              Hub               @relation(fields: [hubId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  creator          User?             @relation("CollectionCreator", fields: [creatorUserId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  parentCollection Collection?       @relation("CollectionHierarchy", fields: [parentCollectionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  children         Collection[]      @relation("CollectionHierarchy")
  resources        Resource[]        @relation("CollectionResources")
  linkedBy         Resource[]        @relation("ResourceLinkedCollection")
  collectionTags   CollectionTag[]
  shares           CollectionShare[]
  saves            CollectionSave[]
  exportJobs       ExportJob[]

  @@unique([hubId, slug], map: "collections_hub_slug_unique")
  @@index([published, updatedAt(sort: Desc)], map: "idx_collections_published_updated_at")
  @@index([parentCollectionId], map: "idx_collections_parent_collection_id")
  @@map("collections")
}

model CollectionShare {
  collectionId String   @map("collection_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  role         String   @db.VarChar(16)
  source       String   @db.VarChar(16)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([collectionId, userId])
  @@index([userId], map: "idx_collection_shares_user_id")
  @@map("collection_shares")
}

model CollectionSave {
  collectionId String   @map("collection_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  savedAt      DateTime @default(now()) @map("saved_at") @db.Timestamptz(6)

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([collectionId, userId])
  @@index([userId], map: "idx_collection_saves_user_id")
  @@map("collection_saves")
}

model Link {
  id           String   @id @default(dbgenerated("app_uuid_v7()")) @db.Uuid
  canonicalUrl String   @unique @map("canonical_url")
  urlHash      String   @unique @map("url_hash") @db.VarChar(64)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  resources Resource[]

  @@map("links")
}

model Resource {
  id                 String   @id @default(dbgenerated("app_uuid_v7()")) @db.Uuid
  collectionId       String   @map("collection_id") @db.Uuid
  linkId             String?  @map("link_id") @db.Uuid
  kind               String   @db.VarChar(24)
  linkedCollectionId String?  @map("linked_collection_id") @db.Uuid
  titleOverride      String?  @map("title_override") @db.VarChar(255)
  position           Int
  version            BigInt   @default(1)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  collection       Collection    @relation("CollectionResources", fields: [collectionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  link             Link?         @relation(fields: [linkId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  linkedCollection Collection?   @relation("ResourceLinkedCollection", fields: [linkedCollectionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  resourceTags     ResourceTag[]

  @@unique([collectionId, position], map: "resources_collection_position_unique")
  @@index([collectionId, updatedAt(sort: Desc)], map: "idx_resources_collection_updated_at")
  @@map("resources")
}

model Tag {
  id        String   @id @default(dbgenerated("app_uuid_v7()")) @db.Uuid
  name      String   @unique @db.VarChar(80)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  collectionTags CollectionTag[]
  resourceTags   ResourceTag[]

  @@map("tags")
}

model CollectionTag {
  collectionId String @map("collection_id") @db.Uuid
  tagId        String @map("tag_id") @db.Uuid

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tag        Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([collectionId, tagId])
  @@map("collection_tags")
}

model ResourceTag {
  resourceId String @map("resource_id") @db.Uuid
  tagId      String @map("tag_id") @db.Uuid

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([resourceId, tagId])
  @@map("resource_tags")
}

model ExportJob {
  id                String   @id @default(dbgenerated("app_uuid_v7()")) @db.Uuid
  hubId             String   @map("hub_id") @db.Uuid
  collectionId      String   @map("collection_id") @db.Uuid
  requestedByUserId String?  @map("requested_by_user_id") @db.Uuid
  format            String   @db.VarChar(16)
  status            String   @db.VarChar(16)
  outputRef         String?  @map("output_ref")
  errorMessage      String?  @map("error_message")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  hub         Hub        @relation(fields: [hubId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  collection  Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  requestedBy User?      @relation(fields: [requestedByUserId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([collectionId, createdAt(sort: Desc)], map: "idx_export_jobs_collection_created_at")
  @@index([status, createdAt(sort: Desc)], map: "idx_export_jobs_status_created_at")
  @@map("export_jobs")
}

model Session {
  id        String   @id @default(dbgenerated("app_uuid_v7()")) @db.Uuid
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  token     String   @unique
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_sessions_user_id")
  @@map("sessions")
}

model Account {
  id                    String    @id @default(dbgenerated("app_uuid_v7()")) @db.Uuid
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id") @db.Uuid
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamptz(6)
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamptz(6)
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_accounts_user_id")
  @@map("accounts")
}

model Verification {
  id         String   @id @default(dbgenerated("app_uuid_v7()")) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([identifier], map: "idx_verifications_identifier")
  @@map("verifications")
}
