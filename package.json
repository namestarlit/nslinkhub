{
  "name": "nslinkhub",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "bun run --cwd apps/api build",
    "check:boundaries": "bun tooling/check-client-boundaries.ts",
    "typecheck:types": "bun run --cwd packages/types typecheck",
    "verify": "bun run check:boundaries && bun run typecheck:types && bun run --cwd apps/api verify",
    "format": "bun run --cwd apps/api format",
    "start": "bun run --cwd apps/api start",
    "start:dev": "bun run --cwd apps/api start:dev",
    "start:debug": "bun run --cwd apps/api start:debug",
    "start:prod": "bun run --cwd apps/api start:prod",
    "lint": "bun run --cwd apps/api lint",
    "test": "bun run --cwd apps/api test",
    "test:e2e": "bun run --cwd apps/api test:e2e"
  },
  "trustedDependencies": [
    "@prisma/engines",
    "prisma",
    "unrs-resolver"
  ]
}
